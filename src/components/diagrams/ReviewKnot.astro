---
// One problem, many candidate solutions. The post's point is judgment:
// something can work and still be the wrong shape of change. Scope and
// confidence get the axes; review cost becomes bubble size.

const chartId = "review-knot-chart";

const candidates = [
  { x: 18, y: 22, r: 4 },
  { x: 26, y: 46, r: 4 },
  { x: 34, y: 18, r: 5 },
  { x: 42, y: 58, r: 5 },
  { x: 48, y: 36, r: 6 },
  { x: 56, y: 66, r: 5 },
  { x: 66, y: 20, r: 8 },
  { x: 72, y: 48, r: 7 },
  { x: 84, y: 28, r: 9 },
];

const chosen = { x: 30, y: 78, r: 4 };
const generated = { x: 76, y: 40, r: 13 };
---

<figure
  class="rk diagram"
  role="img"
  aria-label="A bubble chart of candidate solutions. Scope is on the horizontal axis, confidence is on the vertical axis, and bubble size represents review cost. The generated option is larger and farther right, while the better fit is smaller and higher."
>
  <div class="rk-wrap">
    <canvas
      id={chartId}
      class="rk-canvas"
      width="620"
      height="360"
      data-candidates={JSON.stringify(candidates)}
      data-chosen={JSON.stringify(chosen)}
      data-generated={JSON.stringify(generated)}
      aria-hidden="true"
    ></canvas>
    <span class="rk-label rk-label-generated">GENERATED</span>
    <span class="rk-label rk-label-chosen">BETTER FIT</span>
  </div>
</figure>

<script>
  import {
    BubbleController,
    CategoryScale,
    Chart,
    Legend,
    LinearScale,
    PointElement,
    Tooltip,
  } from "chart.js";

  Chart.register(
    BubbleController,
    CategoryScale,
    Legend,
    LinearScale,
    PointElement,
    Tooltip
  );

  const canvas = document.getElementById("review-knot-chart");

  if (canvas instanceof HTMLCanvasElement) {
    const css = getComputedStyle(canvas);
    const accent = css.getPropertyValue("--accent").trim() || "#2a4fd6";
    const muted = css.getPropertyValue("--muted").trim() || "#6d758d";
    const border = "rgba(42,79,214,0.22)";
    const grid = "rgba(42,79,214,0.12)";
    const font = css.getPropertyValue("--font-mark").trim() || "monospace";
    const candidates = JSON.parse(canvas.dataset.candidates || "[]");
    const chosen = JSON.parse(canvas.dataset.chosen || "{}");
    const generated = JSON.parse(canvas.dataset.generated || "{}");

    new Chart(canvas, {
      type: "bubble",
      data: {
        datasets: [
          {
            data: candidates,
            backgroundColor: "rgba(42,79,214,0.35)",
            borderWidth: 0,
            hoverRadius: 0,
          },
          {
            data: [generated],
            backgroundColor: accent,
            borderWidth: 0,
            hoverRadius: 0,
          },
          {
            data: [chosen],
            backgroundColor: accent,
            borderColor: accent,
            borderWidth: 2,
            hoverRadius: 0,
          },
        ],
      },
      options: {
        animation: false,
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { enabled: false },
        },
        elements: {
          point: {
            hitRadius: 0,
          },
        },
        scales: {
          x: {
            min: 0,
            max: 100,
            grid: {
              color: grid,
              drawTicks: false,
            },
            border: {
              color: accent,
              width: 1.5,
            },
            ticks: {
              display: false,
            },
            title: {
              display: true,
              text: "SCOPE",
              color: accent,
              font: {
                family: font,
                size: 12,
              },
              padding: { top: 12 },
            },
          },
          y: {
            min: 0,
            max: 100,
            grid: {
              color: grid,
              drawTicks: false,
            },
            border: {
              color: accent,
              width: 1.5,
            },
            ticks: {
              display: false,
            },
            title: {
              display: true,
              text: "CONFIDENCE",
              color: accent,
              font: {
                family: font,
                size: 12,
              },
              padding: { bottom: 12 },
            },
          },
        },
      },
    });

    const wrap = canvas.parentElement;
    if (wrap) {
      wrap.style.setProperty("--label-color", muted);
    }
  }
</script>

<style>
  .rk {
    --diagram-max: 620px;
  }

  .rk-wrap {
    position: relative;
    width: 100%;
    min-height: 360px;
  }

  .rk-canvas {
    display: block;
    width: 100%;
    height: 360px;
  }

  .rk-label {
    position: absolute;
    font-family: var(--font-mark, monospace);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--label-color, var(--muted));
    pointer-events: none;
    white-space: nowrap;
  }

  .rk-label-generated {
    right: 7%;
    top: 43%;
  }

  .rk-label-chosen {
    left: 20%;
    top: 14%;
  }
</style>
