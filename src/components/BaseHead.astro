---
// All <head> metadata lives here: SEO, Open Graph, Twitter card,
// favicon, fonts, RSS autodiscovery. Reused by every page.
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR, TWITTER_HANDLE } from "../consts";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  // Page type — "article" gets extra OG tags + BlogPosting schema.
  type?: "website" | "article";
  publishedTime?: Date;
  updatedTime?: Date;
  image?: string;
  imageAlt?: string;
  // Path to a Markdown twin of this page (e.g. "/my-post.md"), exposed to
  // LLMs and agents via a rel="alternate" link.
  markdown?: string;
}

const {
  title,
  description,
  type = "website",
  publishedTime,
  updatedTime,
  // Branded card generated at build time by scripts/generate-og.mjs.
  image = "/og/default.png",
  imageAlt,
  markdown,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
// Home page uses the bare site title; inner pages append it.
const fullTitle = title === SITE_TITLE ? title : `${title} — ${SITE_TITLE}`;
const ogImageAlt = imageAlt ?? `${title} — ${SITE_TITLE}`;

// ── Structured data (JSON-LD) ──────────────────────────────────
// WebSite + Person on every page; BlogPosting layered on for articles.
// Helps search engines understand authorship, dates, and the byline,
// and qualifies posts for article rich results.
const author = {
  "@type": "Person",
  name: AUTHOR,
  url: Astro.site?.href,
  sameAs: [`https://x.com/${TWITTER_HANDLE.replace(/^@/, "")}`],
};

const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  ...(type === "article"
    ? {
        "@type": "BlogPosting",
        headline: title,
        description,
        image: imageURL.href,
        url: canonicalURL.href,
        mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
        author,
        publisher: author,
        ...(publishedTime && { datePublished: publishedTime.toISOString() }),
        dateModified: (updatedTime ?? publishedTime)?.toISOString(),
      }
    : {
        "@type": "WebSite",
        name: SITE_TITLE,
        description: SITE_DESCRIPTION,
        url: Astro.site?.href,
        author,
      }),
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary meta -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR} />
<link rel="canonical" href={canonicalURL} />
<meta name="theme-color" content="#f4f1ea" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
{
  type === "article" && (
    <meta property="article:author" content={AUTHOR} />
  )
}
{
  type === "article" && publishedTime && (
    <meta
      property="article:published_time"
      content={publishedTime.toISOString()}
    />
  )
}
{
  type === "article" && updatedTime && (
    <meta
      property="article:modified_time"
      content={updatedTime.toISOString()}
    />
  )
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

<!-- Icons -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- Fonts: self-hosted, preloaded for fast first paint.
     Newsreader carries the body, so it's the priority preload. -->
<link
  rel="preload"
  href="/fonts/Newsreader-Roman.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/DepartureMono-Regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<!-- Markdown twin + llms.txt: clean, layout-free copies for LLMs/agents -->
{
  markdown && (
    <link rel="alternate" type="text/markdown" href={markdown} title={fullTitle} />
  )
}
<link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

<!-- RSS autodiscovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL("rss.xml", Astro.site)}
/>

<!-- Privacy-friendly analytics by Plausible (production only) -->
{
  import.meta.env.PROD && (
    <>
      <script
        is:inline
        defer
        src="https://plausible.io/js/pa-KC__GnJbz3feUPFY6gZE9.js"
      />
      <script is:inline>
        window.plausible =
          window.plausible ||
          function () {
            (plausible.q = plausible.q || []).push(arguments);
          };
        plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          };
        plausible.init();
      </script>
    </>
  )
}
