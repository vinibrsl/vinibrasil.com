---
import Base from "../layouts/Base.astro";
import Figure from "../components/Figure.astro";

/**
 * Travel log, grouped by year (newest first). Each entry is a place — a city
 * or region — with the country shown beneath, plus an optional one-line note.
 * To log a trip, add it to the right year's `places` array.
 */
type Place = {
  place: string;
  country: string;
  note?: string;
  image?: { src: string; alt: string; caption?: string };
};
type Year = { year: string; places: Place[] };

