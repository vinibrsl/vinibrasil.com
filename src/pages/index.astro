---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <p class="intro">
    Hi, I'm Vinicius. I build software and write about it here —
    <em>plainly, without the fluff.</em>
  </p>

  {
    posts.length === 0 ? (
      <p class="muted">No posts yet. Soon.</p>
    ) : (
      <ul class="entries">
        {posts.map((post) => (
          <li>
            <a href={`/${post.id}/`}>
              <span class="entry-title">{post.data.title}</span>
              <FormattedDate date={post.data.pubDate} />
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Base>
